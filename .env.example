# ─────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev. In production these are set in
# Vercel project settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Supabase project (leasing-tracker). When BOTH are set, the app
# treats Supabase as the source of truth and falls back to the
# local-first Dexie/file flow only when they're missing.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Optional passcode gate. The app SHA-256-hashes the entered password
# and compares against this value. Generate with:
#   echo -n 'YourPassword' | shasum -a 256
# Leave blank to disable the gate (dev mode).
VITE_PASSWORD_HASH=

# Mapbox token for the Map tab. Public pk.* token; reusable from
# PortViz if that project already has one. Without this the Map tab
# shows a "token missing" state but the rest of the app still works.
VITE_MAPBOX_TOKEN=

# ─────────────────────────────────────────────────────────────────
# MCP server (api/mcp.ts) — server-side only, never bundled into
# the browser. Required for the MCP server to function; absence
# only breaks /api/mcp, not the rest of the app.
# ─────────────────────────────────────────────────────────────────

# Service-role key from Supabase → Project Settings → API → service_role.
# This bypasses RLS — keep it out of any VITE_-prefixed var or client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Defaults to VITE_SUPABASE_URL when unset. Set explicitly
# if you want the MCP to talk to a different Supabase project.
SUPABASE_URL=
